#!/usr/bin/env zsh

function usage() {
	[[ $# -ge 1 ]] && echo >&2 error: "$@"
	cat >&2 <<EOF
Usage: ${0##*/} <directory> [<pattern>]

Interactive tag finder using fzf and tags files generated by Exuberant Ctags.

Requirements:
  - zsh shell
    - version: zsh 5.8.1 (x86_64-ubuntu-linux-gnu)
  - fzf: A command-line fuzzy finder
    - version: 0.65.2 (brew)
    - source: https://github.com/junegunn/fzf
EOF
	exit 2
}

if [ "$#" -lt 1 ]; then
	usage "missing positional argument <directory>"
fi

set -e

cd $1

pattern_file="/tmp/ft-pattern"
touch ${pattern_file}

__get_file_preview_renderer() {
	if command -v bat 2>&1 1>/dev/null; then
		echo "bat --color=always --decorations=always --style=numbers {1} --highlight-line {2}";
	else
		# get meaningful preview:
		# 1. highlight query with grep, match everything else without color
		# 1. add number lines with nl
		echo "grep --color=always --regexp '{q}' --regexp '^' {1} | nl";
	fi
}

fzf_options=()
fzf_header=""

fzf_header+="PWD: ${PWD}"

fzf_options+=( --header="${fzf_header}" )

find . \
	-path "*/.git" -prune \
	-o -name tags \
	-print \
	| xargs cat \
	| awk -F'\t' '{
    if (match($0, /line:([0-9]+)/, lines)) {
      line_num = lines[1]
    }
    printf "%s:%s" $2, line_num
}' \
	| fzf \
		"${fzf_options[@]}" \
		--layout=reverse   \
		--keep-right \
		--preview "[ -z {2} ] || $(__get_file_preview_renderer)" \
		--preview-window 'right,70%,border-left,+{2}+3/3' \
	| while read fn; do
		# Output each selected file name with proper quoting.
		printf "%s%b" ${(q)fn} ${separator}
	done
